// Persofit Content Hub — Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enum support in Prisma, so status fields are
// plain strings constrained at the application layer:
// Slideshow.status:  DRAFT | SCHEDULED | GENERATING | POSTED | FAILED
// Schedule.status:   PENDING | GENERATING | POSTED | FAILED

model TiktokAccount {
  id               String    @id @default(cuid())
  name             String
  accessToken      String
  refreshToken     String?
  tokenExpiresAt   DateTime?
  accountId        String
  avatarUrl        String?
  connected        Boolean   @default(true)
  createdAt        DateTime  @default(now())

  slideshows         Slideshow[]
  posts              PostHistory[]
  slideshowTemplates SlideshowTemplate[]
}

model Slideshow {
  id              String         @id @default(cuid())
  name            String
  caption         String         @default("")
  hashtags        String         @default("")
  status          String         @default("DRAFT")
  tiktokAccountId String?
  tiktokAccount   TiktokAccount? @relation(fields: [tiktokAccountId], references: [id])

  // Output Format — the final rendered dimensions for every slide in this
  // slideshow. aspectRatio is a preset key (see src/lib/aspect-ratio-presets.ts)
  // or "custom"; outputWidth/outputHeight are the actual pixel dimensions
  // slides get resized to during generation.
  aspectRatio String @default("9:16")
  outputWidth  Int    @default(1080)
  outputHeight Int    @default(1920)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slides    Slide[]
  schedules Schedule[]
  posts     PostHistory[]
}

model Slide {
  id          String    @id @default(cuid())
  slideshowId String
  slideshow   Slideshow @relation(fields: [slideshowId], references: [id], onDelete: Cascade)
  order       Int

  // Image Prompt System — combined into finalPrompt at generation time
  // (see src/lib/prompt-builder.ts). Reference image is optional so a
  // slide can be pure text-to-image, but the current UI still requires
  // one since generation always calls the images/edits endpoint.
  // imageMode controls how the slide image is produced:
  //   "generate"    — send referenceImagePath + prompt to OpenAI (default)
  //   "random-pick" — randomly select one image from randomImagePool at generation time
  imageMode          String  @default("generate")
  referenceImagePath String?
  randomImagePool    String? // JSON-encoded array of /uploads/reference/... paths
  slidePurpose        String  @default("hook")
  referenceType       String  @default("mirror_selfie")
  variationAngle      String  @default("shirt_too_tight")
  customPrompt        String?
  variationDirection  String?
  finalPrompt         String?

  // Text Overlay System — rendered onto the generated image by
  // src/lib/overlay-renderer.ts, never generated by the AI image model.
  overlayText     String?
  overlaySubtext  String?
  textPosition    String  @default("center")
  textSize        String  @default("large")
  textAlign       String  @default("center")
  textColor       String  @default("white")
  textAccentColor String  @default("#00FF87")
  textStyle       String  @default("bold")
  textShadow      Boolean @default(true)
  textBoxEnabled  Boolean @default(false)
  textBoxOpacity  Float   @default(0.45)

  // Pipeline: generatedImagePath (raw from OpenAI) -> processedImagePath
  // (resized/cropped to the slideshow's output dimensions) -> finalImagePath
  // (processed + baked-in text overlay). finalImagePath is what gets posted.
  textOverlayEnabled Boolean @default(false)

  generatedImagePath String?
  processedImagePath String?
  finalImagePath      String?
  status               String  @default("draft") // draft | generating | done | failed
  errorMessage         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id          String    @id @default(cuid())
  slideshowId String
  slideshow   Slideshow @relation(fields: [slideshowId], references: [id], onDelete: Cascade)
  postTime    String    // "HH:mm" 24h daily time
  dates       String    // JSON-encoded array of ISO date strings
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
}

model PostHistory {
  id              String        @id @default(cuid())
  slideshowId     String
  slideshow       Slideshow     @relation(fields: [slideshowId], references: [id], onDelete: Cascade)
  tiktokAccountId String?
  tiktokAccount   TiktokAccount? @relation(fields: [tiktokAccountId], references: [id])
  postedAt        DateTime      @default(now())
  status          String        // posted | failed
  errorMessage    String?
  generatedImages String        // JSON-encoded array of image paths
  views           Int           @default(0)
  likes           Int           @default(0)
}

model SlideshowTemplate {
  id                 String    @id @default(cuid())
  name               String
  caption            String    @default("")
  hashtags           String    @default("")
  tiktokAccountId    String?
  tiktokAccount      TiktokAccount? @relation(fields: [tiktokAccountId], references: [id])
  concept            String
  variables          String?
  slideCount         Int       @default(7)
  referenceImagePath String?
  aspectRatio        String    @default("9:16")
  outputWidth        Int       @default(1080)
  outputHeight       Int       @default(1920)
  postTime           String    @default("09:00")
  scheduleDays       String    @default("[\"mon\",\"tue\",\"wed\",\"thu\",\"fri\",\"sat\",\"sun\"]")
  autoPost           Boolean   @default(false)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  runs           SlideshowTemplateRun[]
  templateSlides SlideshowTemplateSlide[]
}

model SlideshowTemplateSlide {
  id                 String            @id @default(cuid())
  templateId         String
  template           SlideshowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order              Int
  // "ai-auto": GPT-4o plans this slide fresh each run
  // "generate": stored customPrompt, generates new image each run
  // "random-pick": picks from randomImagePool each run
  imageMode          String            @default("ai-auto")
  referenceImagePath String?
  randomImagePool    String            @default("[]")
  customPrompt       String?
  variationDirection String?
  textOverlayEnabled Boolean           @default(false)
  overlayText        String?
  overlaySubtext     String?
  textPosition       String            @default("center")
  textSize           String            @default("large")
  textAlign          String            @default("center")
  textColor          String            @default("white")
  textAccentColor    String            @default("#00FF87")
  textStyle          String            @default("bold")
  textShadow         Boolean           @default(true)
  textBoxEnabled     Boolean           @default(false)
  textBoxOpacity     Float             @default(0.45)
}

model SlideshowTemplateRun {
  id           String            @id @default(cuid())
  templateId   String
  template     SlideshowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  slideshowId  String?
  status       String            @default("GENERATING")
  // GENERATING | AWAITING_APPROVAL | POSTED | FAILED | REJECTED
  scheduledFor String
  errorMessage String?
  createdAt    DateTime          @default(now())
}

model Settings {
  id                   String  @id @default("singleton")
  openaiApiKey         String?
  imageModel           String  @default("gpt-image-2")
  imageQuality         String  @default("medium")
  defaultAspectRatio   String  @default("9:16")
  defaultOutputWidth   Int     @default(1080)
  defaultOutputHeight  Int     @default(1920)
  globalBrandPrompt    String?
  tiktokClientKey      String?
  tiktokClientSecret   String?
  tiktokRedirectUri    String?
}
